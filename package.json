{
  "name": "tandem",
  "version": "1.0.0",
  "description": "TANDEM — Real-time Collaborative Code Editor",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start:client": "cd client && npm run dev",
    "start:server": "cd server && npm run dev",
    "dev": "concurrently \"npm run start:client\" \"npm run start:server\"",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": ["collaborative", "code-editor", "real-time", "websocket"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
